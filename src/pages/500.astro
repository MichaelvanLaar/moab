---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Serverfehler" description="Ein unerwarteter Fehler ist aufgetreten." noindex>
  <section class="mx-auto max-w-prose px-4 py-16 text-center">
    <p class="text-text-muted text-sm tracking-wide uppercase">500</p>
    <h1 class="mt-2 text-4xl font-bold">Serverfehler</h1>
    <p class="mt-4">Ein unerwarteter Fehler ist aufgetreten. Bitte versuche es später erneut.</p>
    <p class="mt-6"><a href="/">Zurück zur Startseite</a></p>
  </section>
</BaseLayout>
