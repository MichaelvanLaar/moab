---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const dateFormatter = new Intl.DateTimeFormat('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title="Blog" description="Alle Beiträge.">
  <section class="mx-auto max-w-prose px-4 py-12">
    <h1 class="text-4xl font-bold">Blog</h1>
    <ul class="mt-8 space-y-6">
      {
        posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`} class="block">
              <h2 class="text-2xl font-semibold">{post.data.title}</h2>
              <p class="text-text-muted mt-1 text-sm">
                <time datetime={post.data.pubDate.toISOString()}>
                  {dateFormatter.format(post.data.pubDate)}
                </time>
              </p>
              <p class="mt-2">{post.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
