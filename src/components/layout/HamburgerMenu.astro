---
interface Props {
  labelOpen?: string;
  labelClose?: string;
}

const { labelOpen = 'Menü öffnen', labelClose = 'Menü schließen' } = Astro.props;
---

<nav class="hamburger" aria-label="Hauptnavigation">
  <input id="hamburger-toggle" class="hamburger__toggle" type="checkbox" />
  <label class="hamburger__button" for="hamburger-toggle">
    <span class="hamburger__icon" aria-hidden="true"></span>
    <span class="hamburger__label-open">{labelOpen}</span>
    <span class="hamburger__label-close">{labelClose}</span>
  </label>

  <div class="hamburger__panel" id="hamburger-panel">
    <slot />
  </div>
</nav>

<style>
  .hamburger {
    position: relative;
  }

  .hamburger__toggle {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .hamburger__button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-subtle);
    color: var(--color-text);
  }

  .hamburger__icon {
    display: inline-block;
    width: 1.25rem;
    height: 2px;
    background: currentColor;
    position: relative;
  }
  .hamburger__icon::before,
  .hamburger__icon::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: currentColor;
    transition: transform 150ms ease;
  }
  .hamburger__icon::before {
    top: -0.4rem;
  }
  .hamburger__icon::after {
    top: 0.4rem;
  }

  .hamburger__label-close {
    display: none;
  }

  .hamburger__panel {
    display: none;
    position: absolute;
    top: calc(100% + var(--space-2));
    right: 0;
    min-width: 16rem;
    padding: var(--space-4);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  .hamburger:has(.hamburger__toggle:checked) .hamburger__panel {
    display: block;
  }
  .hamburger:has(.hamburger__toggle:checked) .hamburger__label-open {
    display: none;
  }
  .hamburger:has(.hamburger__toggle:checked) .hamburger__label-close {
    display: inline;
  }

  .hamburger__toggle:focus-visible + .hamburger__button {
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }
</style>
